{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile inside the J. Cruzeiro system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "perfil": { "type": "string", "enum": ["Admin", "Controlador", "Separador", "Gerente"] },
        "cargo": { "type": "string" },
        "setor": { "type": "string" },
        "loja": { "type": "string" },
        "ativo": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "lastLogin": { "type": "string" }
      },
      "required": ["id", "nome", "email", "perfil", "cargo", "setor", "loja", "ativo", "createdAt", "updatedAt"]
    },
    "Amostra": {
      "title": "Amostra",
      "description": "A sample item tracked in Central Distribution (CD) and showrooms",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "codigoAdm": { "type": "string" },
        "descricao": { "type": "string" },
        "marca": { "type": "string" },
        "categoria": { "type": "string" },
        "tamanho": { "type": "string" },
        "colecao": { "type": "string" },
        "unidade": { "type": "string" },
        "saldoAtual": { "type": "number" },
        "estoqueMinimo": { "type": "number" },
        "localizacaoCd": { "type": "string" },
        "status": { "type": "string", "enum": ["ativo", "inativo", "pendente", "avariado"] },
        "fotoUrl": { "type": "string" },
        "observacoes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "codigoAdm", "descricao", "marca", "categoria", "tamanho", "unidade", "saldoAtual", "estoqueMinimo", "status", "createdAt", "updatedAt"]
    },
