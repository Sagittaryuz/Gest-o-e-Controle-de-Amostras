  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of all authorized J. Cruzeiro personnel"
    },
    "amostras": {
      "schema": "Amostra",
      "description": "Inventory ledger of dynamic showcase tiles and products"
    },
    "movimentacoes": {
      "schema": "MovimentacaoEstoque",
      "description": "Ledger recording stock counts additions and subtraction"
    },
    "solicitacoes": {
      "schema": "Solicitacao",
      "description": "Showroom distribution requests"
    },
    "protocolos": {
      "schema": "ProtocoloEnvio",
      "description": "Dispatched order receipts"
    },
    "recebimentos": {
      "schema": "Recebimento",
      "description": "In-store confirmation records"
    },
    "exposicoes": {
